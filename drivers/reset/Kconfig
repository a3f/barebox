config ARCH_HAS_RESET_CONTROLLER
	bool

menuconfig RESET_CONTROLLER
	bool "Reset Controller Support"
	default y if ARCH_HAS_RESET_CONTROLLER
	help
	  Generic Reset Controller support.

	  This framework is designed to abstract reset handling of devices
	  via GPIOs or SoC-internal reset controller modules.

	  If unsure, say no.

if RESET_CONTROLLER

config RESET_IMX7
	bool "i.MX7 Reset Driver"
	default SOC_IMX7D
	select MFD_SYSCON
	help
	  This enables the reset controller driver for i.MX7 SoCs.

config RESET_STM32F
	bool "STM32F Reset Driver"
	help
	  This enables the reset controller driver for STM32F MCUs.

config RESET_STM32MP
	bool "STM32MP Reset Driver"
	default ARCH_STM32MP
	help
	  This enables the reset controller driver for STM32MP SoCs.

endif
